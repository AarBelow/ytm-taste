LASTFM_API_KEY=
LASTFM_API_SECRET=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=
SECRET_KEY=

# Public address the app is reached at. Defaults to http://127.0.0.1:8000 for
# local development; set it to the deployed https:// origin (no trailing slash)
# and register "<origin>/auth/callback" as an authorized redirect URI in Google
# Cloud Console. Also decides whether the session cookie is HTTPS-only.
YTM_BASE_URL=

# Where the SQLite file lives. Defaults to data/ytm_taste.db, which is relative
# to the working directory; deployed, point it at a mounted volume or the
# database dies with the container.
YTM_DB_PATH=
